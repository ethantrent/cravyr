# Cravyr Mobile - Environment Variables
# Copy this file to .env and fill in your values

# API Server (use 10.0.2.2 for Android emulator, localhost for iOS simulator)
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (required for Google Sign-In — obtain from Google Cloud Console)
# Web Application OAuth client ID (not iOS or Android type)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS OAuth client ID
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Reversed iOS client ID (com.googleusercontent.apps.XXXX) — used as iosUrlScheme
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id

# --- Production (EAS free tier: https://expo.dev/pricing) ---
# Point EXPO_PUBLIC_API_URL at your Render URL, e.g. https://cravyr-api.onrender.com
# Do not commit real keys. For EAS builds, set EXPO_PUBLIC_SUPABASE_* in Expo project
# Environment variables (or eas secret:create) — see apps/api/.env.example Render section.
