# Cravyr Mobile - Environment Variables
# Copy this file to .env and fill in your values

# --- Local / emulator (default) ---
# API Server: 10.0.2.2 = Android emulator → host machine; use http://localhost:4000 for iOS simulator if API runs on host
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000

# --- Production smoke test (physical device or when pointing at Render) ---
# EXPO_PUBLIC_API_URL=https://cravyr-api.onrender.com
#
# Checklist (same day):
#   1. Uncomment or set EXPO_PUBLIC_API_URL to your Render API (see env.smoke.template).
#   2. Repo root: pnpm prod:verify  (smoke Render + mobile tsc), or pnpm smoke:prod then pnpm prod:smoke:mobile
#   3. Dashboards: pnpm prod:dashboards  (Supabase / Google / Expo checklist)
#   4. Device UAT order: pnpm prod:device:uat
#   5. apps/mobile: pnpm start — on device run the UAT list (incl. Settings → Privacy Policy).
#   6. EAS + submit when ready: pnpm prod:eas

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth (required for Google Sign-In — obtain from Google Cloud Console)
# Web Application OAuth client ID (not iOS or Android type)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# iOS OAuth client ID
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# Reversed iOS client ID (com.googleusercontent.apps.XXXX) — used as iosUrlScheme
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=com.googleusercontent.apps.your-ios-client-id

# Optional: override privacy policy URL opened from Settings (defaults to EXPO_PUBLIC_API_URL + /privacy)
# EXPO_PUBLIC_PRIVACY_URL=https://cravyr-api.onrender.com/privacy

# --- Production (EAS free tier: https://expo.dev/pricing) ---
# Point EXPO_PUBLIC_API_URL at your Render URL, e.g. https://cravyr-api.onrender.com
# Do not commit real keys. For EAS builds, set EXPO_PUBLIC_SUPABASE_* in Expo project
# Environment variables (or eas secret:create) — see apps/api/.env.example Render section.

# =============================================================================
# EAS production profile (apps/mobile/eas.json)
# =============================================================================
# eas.json production only sets EXPO_PUBLIC_API_URL. You MUST define these in Expo
# (expo.dev → Project → Environment variables → Production) or builds will miss Supabase:
#   EXPO_PUBLIC_SUPABASE_URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY
# Optional: mirror other EXPO_PUBLIC_* from this file for Google Sign-In on store builds.
#
# GitHub EAS workflow (.github/workflows/eas-build.yml): add repository secret EXPO_TOKEN
# (expo.dev → Access tokens) for CI-triggered builds.

# =============================================================================
# App Store / Play Console (manual checklist)
# =============================================================================
# Privacy policy URL (App Store Connect + Play listing): https://cravyr-api.onrender.com/privacy
# Apple: Developer Program, Sign in with Apple, replace ascAppId in eas.json submit.production.ios
# Android: create Play service account JSON → save as apps/mobile/google-sa.json (gitignored)
# Screenshots: onboarding, discover, restaurant detail, saved list (required sizes per store)
# Distribution: TestFlight (iOS) and Play internal testing track before production rollout.
#
# EAS submit (after builds): from apps/mobile, eas submit --profile production --platform ios|android

# =============================================================================
# Post-MVP ops (optional)
# =============================================================================
# Google Cloud: budget + alert on the Places billing project (see apps/api/.env.example).
# Render: paid tier if keepalive is not enough; product backlog (push UX, analytics, marketing site).
